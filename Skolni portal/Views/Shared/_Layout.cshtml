<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SPŠ Trutnovská</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light-custom">
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3 sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="#">
                <span class="bg-primary text-white rounded px-2 py-1 fs-6">SP</span>
                SPŠ Trutnovská
            </a>
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav gap-3 fw-medium">
                    <li class="nav-item"><a class="nav-link text-dark" href="#">O škole</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Obory</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Aktuality</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Kontakt</a></li>
                </ul>
            </div>
            <div>
                <a href="#" class="btn btn-outline-dark fw-bold rounded-pill px-4">Přihlásit se</a>
            </div>
        </div>
    </nav>

    <main class="container py-5">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>