<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SPŠ Trutnovská</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar container">
        <div class="navbar-brand">
            <span style="background: var(--primary-blue); color: white; padding: 4px 8px; border-radius: 6px;">SP</span>
            SPŠ Trutnovská
        </div>
        <nav class="navbar-links">
            <a href="#">O škole</a>
            <a href="#">Obory</a>
            <a href="#">Aktuality</a>
            <a href="#">Kontakt</a>
        </nav>
        <div>
            <a href="#" class="btn-login">Přihlásit se</a>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>