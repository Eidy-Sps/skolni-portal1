@{
    ViewData["Title"] = "O škole";
}

<div class="mb-5 pb-3">
    <h1 class="display-4 fw-bold text-dark mb-4">O škole</h1>
    
    <div class="row align-items-center mb-5">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <img src="https://via.placeholder.com/500x400?text=SPŠ+Trutnovská" alt="SPŠ Trutnovská" class="img-fluid rounded-4 shadow">
        </div>
        <div class="col-lg-6">
            <h2 class="fw-bold text-dark mb-3">Zdravím vás!</h2>
            <p class="text-muted fs-5 mb-3">
                SPŠ Trutnovská je moderní střední technická škola s dlouhou tradicí. Poskytujeme kvalitní vzdělání v oborech zaměřených na informační technologie, strojírenství, elektrotechniku a stavebnictví.
            </p>
            <p class="text-muted fs-5 mb-3">
                Naší prioritou je připravit studenty nejen na budoucí pracovní kariéru, ale také na život v moderní společnosti. Kombinujeme teoretické znalosti s praktickými dovednostmi prostřednictvím moderního vybavení a zkušených pedagogů.
            </p>
            <p class="text-muted fs-5">
                Už více než 20 let jsme jedním z lídrů v technickém vzdělání v regionu Trutnov. Naši absolventi úspěšně pokračují ve vysokoškolském studiu nebo v pracovním životě.
            </p>
        </div>
    </div>
</div>

<div class="row mb-5">
    <div class="col-md-6 mb-4">
        <div class="card rounded-4 shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-mortarboard fs-2 text-primary"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Kvalitní vzdělání</h5>
                <p class="text-muted mb-0">
                    Akreditované studijní programy v souladu s požadavky trhu práce a mezinárodními standardy.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card rounded-4 shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-pc-horizontal fs-2 text-primary"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Moderní vybavení</h5>
                <p class="text-muted mb-0">
                    Počítačové laboratoře, dílny a učebny s nejnovější technologií pro praktické vyučování.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card rounded-4 shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-people fs-2 text-primary"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Zkušení učitelé</h5>
                <p class="text-muted mb-0">
                    Kvalifikovaní pedagogové s praxí z průmyslu a akademické sféry, kteří se věnují studentům individuálně.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card rounded-4 shadow-sm h-100 border-0">
            <div class="card-body p-4">
                <div class="mb-3">
                    <i class="bi bi-graph-up fs-2 text-primary"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Úspěšní absolventi</h5>
                <p class="text-muted mb-0">
                    Vysoké procento absolventů pokračujících na vysokých školách nebo v zajímavých pracovních pozicích.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="bg-primary bg-opacity-10 rounded-4 p-5 mb-5">
    <h3 class="fw-bold text-dark mb-3">Rychlé fakty</h3>
    <div class="row text-center">
        <div class="col-md-3 mb-3">
            <h4 class="fw-bold text-primary mb-1">20+</h4>
            <p class="text-muted mb-0">Let tradice</p>
        </div>
        <div class="col-md-3 mb-3">
            <h4 class="fw-bold text-primary mb-1">420</h4>
            <p class="text-muted mb-0">Studentů</p>
        </div>
        <div class="col-md-3 mb-3">
            <h4 class="fw-bold text-primary mb-1">38</h4>
            <p class="text-muted mb-0">Učitelů</p>
        </div>
        <div class="col-md-3 mb-3">
            <h4 class="fw-bold text-primary mb-1">6</h4>
            <p class="text-muted mb-0">Oborů</p>
        </div>
    </div>
</div>

<div class="mb-5 pb-5">
    <h3 class="fw-bold text-dark mb-4">Naše vize a mise</h3>
    <div class="row">
        <div class="col-lg-6 mb-4">
            <h5 class="fw-bold text-dark mb-3">Mise</h5>
            <p class="text-muted">
                Poskytovat vysoce kvalitní vzdělání, které připravuje studenty na úspěšné zvládnutí výzev moderní doby a jejich práci v technických oborech.
            </p>
        </div>
        <div class="col-lg-6">
            <h5 class="fw-bold text-dark mb-3">Vize</h5>
            <p class="text-muted">
                Být vedoucí technickou školou v regionu, která je nejen známá vynikající výukou, ale i inovativním přístupem a podporou osobního rozvoje studentů.
            </p>
        </div>
    </div>
</div>
