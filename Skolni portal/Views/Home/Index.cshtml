@{
    ViewData["Title"] = "Úvodní stránka";
}

<div class="row align-items-center mb-5 pb-4">
    <div class="col-lg-8">
        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3">Školní portál 2024/2025</span>
        <h1 class="display-4 fw-bold mb-3 text-dark">Vítejte na portálu<br />SPŠ Trutnovská</h1>
        <p class="lead text-muted mb-4 fs-5">
            Rozvrhy, známky, úkoly a aktuality — vše na jednom místě. <br />
            Studenti a učitelé se přihlašují školním emailem.
        </p>
        <div class="d-flex gap-3">
            <a asp-page="/Account/Login" class="btn btn-outline-dark fw-bold px-4 py-2 rounded-pill">Přihlásit se</a>
            <a href="#obory" class="btn btn-light border fw-bold px-4 py-2 rounded-pill card-hover">Zjistit více</a>
        </div>
    </div>
</div>

<div class="row text-center border-top border-bottom py-5 mb-5 bg-white shadow-sm rounded-4">
    <div class="col-md-4 border-end">
        <h2 class="display-5 fw-bold text-dark mb-0">420</h2>
        <p class="text-muted fw-medium mb-0">Studentů</p>
    </div>
    <div class="col-md-4 border-end">
        <h2 class="display-5 fw-bold text-dark mb-0">38</h2>
        <p class="text-muted fw-medium mb-0">Učitelů</p>
    </div>
    <div class="col-md-4">
        <h2 class="display-5 fw-bold text-dark mb-0">6</h2>
        <p class="text-muted fw-medium mb-0">Oborů</p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold m-0">Aktuality</h3>
    <a href="#" class="text-decoration-none fw-bold">Všechny <i class="bi bi-arrow-right"></i></a>
</div>

<div class="d-flex flex-column gap-3 mb-5">
    <div class="card card-hover border-top-oznameni rounded-4 shadow-sm">
        <div class="card-body p-4">
            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Oznámení</span>
            <h5 class="card-title fw-bold">Třídní schůzky — 20. dubna 2025</h5>
            <p class="card-text text-muted small mb-0"><i class="bi bi-calendar3 me-1"></i> 14. dubna 2025</p>
        </div>
    </div>

    <div class="card card-hover border-top-akce rounded-4 shadow-sm">
        <div class="card-body p-4">
            <span class="badge bg-success bg-opacity-10 text-success mb-2">Akce</span>
            <h5 class="card-title fw-bold">Školní výlet — Krkonoše, přihlašování do 18. dubna</h5>
            <p class="card-text text-muted small mb-0"><i class="bi bi-calendar3 me-1"></i> 12. dubna 2025</p>
        </div>
    </div>

    <div class="card card-hover border-top-prijimacky rounded-4 shadow-sm">
        <div class="card-body p-4">
            <span class="badge text-bg-warning bg-opacity-25 mb-2">Přijímací řízení</span>
            <h5 class="card-title fw-bold">Přijímací zkoušky 2025 — termíny a podmínky</h5>
            <p class="card-text text-muted small mb-0"><i class="bi bi-calendar3 me-1"></i> 10. dubna 2025</p>
        </div>
    </div>
</div>

<h3 class="fw-bold mb-4">Obory</h3>
<div class="row g-4 mb-5 pb-5">
    <div class="col-md-6">
        <div class="card card-hover rounded-4 shadow-sm h-100 p-2">
            <div class="card-body">
                <div class="icon-box bg-it"><i class="bi bi-laptop"></i></div>
                <h5 class="fw-bold">Informační technologie</h5>
                <p class="text-muted small mb-0">4letý obor, maturita</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-hover rounded-4 shadow-sm h-100 p-2">
            <div class="card-body">
                <div class="icon-box bg-stroj"><i class="bi bi-gear"></i></div>
                <h5 class="fw-bold">Strojírenství</h5>
                <p class="text-muted small mb-0">4letý obor, maturita</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-hover rounded-4 shadow-sm h-100 p-2">
            <div class="card-body">
                <div class="icon-box bg-elektro"><i class="bi bi-lightning-charge"></i></div>
                <h5 class="fw-bold">Elektrotechnika</h5>
                <p class="text-muted small mb-0">4letý obor, maturita</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-hover rounded-4 shadow-sm h-100 p-2">
            <div class="card-body">
                <div class="icon-box bg-stavba"><i class="bi bi-rulers"></i></div>
                <h5 class="fw-bold">Stavebnictví</h5>
                <p class="text-muted small mb-0">4letý obor, maturita</p>
            </div>
        </div>
    </div>
</div>