@{
    ViewData["Title"] = "Aktuality";
}

<div class="mb-5 pb-3">
    <h1 class="display-4 fw-bold text-dark mb-4">Aktuality</h1>
    <p class="lead text-muted fs-5 mb-5">
        Sledujte nejnovější zprávy, události a oznámení z našeho školního života.
    </p>

    <div class="d-flex flex-column gap-4 mb-5">
        <!-- Oznámení -->
        <div class="card rounded-4 shadow-sm border-top-oznameni border-0">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">Oznámení</span>
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>20. dubna 2025</small>
                </div>
                <h4 class="fw-bold text-dark mb-3">Třídní schůzky — 20. dubna 2025</h4>
                <p class="text-muted mb-3">
                    Zveme všechny rodiče a zákonné zástupce na třídní schůzky. Schůzky se budou konat ve školní budově.
                </p>
                <div class="d-flex gap-2">
                    <strong class="text-dark">Čas:</strong>
                    <span class="text-muted">18:00 - 20:30</span>
                </div>
                <div class="d-flex gap-2">
                    <strong class="text-dark">Místnost:</strong>
                    <span class="text-muted">Hlavní budova, druhé patro</span>
                </div>
                <a href="#" class="btn btn-sm btn-outline-primary rounded-pill mt-3">Přečíst více</a>
            </div>
        </div>

        <!-- Akce -->
        <div class="card rounded-4 shadow-sm border-top-akce border-0">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">Akce</span>
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>12. dubna 2025</small>
                </div>
                <h4 class="fw-bold text-dark mb-3">Školní výlet — Krkonoše, přihlašování do 18. dubna</h4>
                <p class="text-muted mb-3">
                    Srdečně zveme všechny studenty, aby se zúčastnili našeho tradičního jarního výletu do Krkonoš. Připravili jsme vám zábavný a poučný program.
                </p>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Kdy:</strong>
                    <span class="text-muted">22. - 24. dubna 2025</span>
                </div>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Cena:</strong>
                    <span class="text-muted">1 500 Kč (včetně ubytování a stravy)</span>
                </div>
                <div class="d-flex gap-2">
                    <strong class="text-dark">Přihlášení:</strong>
                    <span class="text-muted">do 18. dubna přes portál</span>
                </div>
                <a href="#" class="btn btn-sm btn-outline-success rounded-pill mt-3">Více informací</a>
            </div>
        </div>

        <!-- Přijímací řízení -->
        <div class="card rounded-4 shadow-sm border-top-prijimacky border-0">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge text-bg-warning bg-opacity-25 px-3 py-2 rounded-pill">Přijímací řízení</span>
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>10. dubna 2025</small>
                </div>
                <h4 class="fw-bold text-dark mb-3">Přijímací zkoušky 2025 — termíny a podmínky</h4>
                <p class="text-muted mb-3">
                    Již brzy se otevírá přihlašování do prvních ročníků pro školní rok 2025/2026. Přijímací zkoušky se budou konat v květnu.
                </p>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Termíny zkoušek:</strong>
                    <span class="text-muted">12. a 19. května 2025</span>
                </div>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Přihlášení:</strong>
                    <span class="text-muted">od 1. března do 30. dubna 2025</span>
                </div>
                <div class="d-flex gap-2">
                    <strong class="text-dark">Forma:</strong>
                    <span class="text-muted">Písemné testy + ústní pohovor</span>
                </div>
                <a href="#" class="btn btn-sm btn-outline-warning rounded-pill mt-3">Podmínky přijetí</a>
            </div>
        </div>

        <!-- Školní ples -->
        <div class="card rounded-4 shadow-sm border-0">
            <div class="card-body p-4" style="border-top: 4px solid #FF6B6B;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge" style="background-color: #FF6B6B; color: white; opacity: 0.2;">Ples</span>
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>5. dubna 2025</small>
                </div>
                <h4 class="fw-bold text-dark mb-3">Tradiční školní ples - Úvodní taneční kurz zdarma!</h4>
                <p class="text-muted mb-3">
                    Těšíme se na vás na našem tradičním školním plese. Poprvé nabízíme zdarma úvodní taneční kurz pro všechny zájemce!
                </p>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Kdy:</strong>
                    <span class="text-muted">25. dubna 2025 od 19:00</span>
                </div>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Kde:</strong>
                    <span class="text-muted">Kongresové centrum Trutnov</span>
                </div>
                <div class="d-flex gap-2">
                    <strong class="text-dark">Taneční kurz:</strong>
                    <span class="text-muted">17. - 24. dubna, 17:00-18:00</span>
                </div>
                <a href="#" class="btn btn-sm rounded-pill mt-3" style="background-color: #FF6B6B; color: white;">Koupit vstupenku</a>
            </div>
        </div>

        <!-- Exkurze -->
        <div class="card rounded-4 shadow-sm border-0">
            <div class="card-body p-4" style="border-top: 4px solid #4ECDC4;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <span class="badge" style="background-color: #4ECDC4; color: white; opacity: 0.2;">Exkurze</span>
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>8. dubna 2025</small>
                </div>
                <h4 class="fw-bold text-dark mb-3">Exkurze do IT společnosti - Praktické poznání pracovního trhu</h4>
                <p class="text-muted mb-3">
                    Studenti oboru Informační technologie navštíví jednu z předních IT společností v regionu a seznámí se s reálným pracovním prostředím.
                </p>
                <div class="d-flex gap-2 mb-2">
                    <strong class="text-dark">Kdy:</strong>
                    <span class="text-muted">16. dubna 2025, 9:00-14:00</span>
                </div>
                <div class="d-flex gap-2">
                    <strong class="text-dark">Určeno pro:</strong>
                    <span class="text-muted">Studenti IT oboru</span>
                </div>
                <a href="#" class="btn btn-sm rounded-pill mt-3" style="background-color: #4ECDC4; color: white;">Podrobnosti</a>
            </div>
        </div>
    </div>

    <div class="bg-light rounded-4 p-5 mb-5">
        <h3 class="fw-bold text-dark mb-4">Chcete být informováni?</h3>
        <p class="text-muted mb-4">Přihlaste se k odběru novinek a nebudete si nic důležitého pamatovat.</p>
        <form class="d-flex gap-2">
            <input type="email" class="form-control form-control-lg rounded-pill" placeholder="Zadejte váš email">
            <button type="submit" class="btn btn-primary btn-lg px-4 rounded-pill fw-bold">Odebírat</button>
        </form>
    </div>
</div>
